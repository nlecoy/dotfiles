#!/usr/bin/env bash
# fish_plugins hash: {{ include "dot_config/fish/fish_plugins" | sha256sum }}
set -euo pipefail
# Sync the managed fisher plugin list whenever it changes. Runs on every machine
# and sorts after the package hooks, so fish already exists (brew on darwin, mise
# elsewhere). No fish means no plugins to manage, so skip.
fish="$(command -v fish || true)"
for candidate in /opt/homebrew/bin/fish /usr/local/bin/fish "$HOME/.local/share/mise/shims/fish"; do
    [ -n "$fish" ] && break
    [ -x "$candidate" ] && fish="$candidate"
done
[ -n "$fish" ] || exit 0
if "$fish" -c 'functions -q fisher' 2>/dev/null; then
    "$fish" -c 'fisher update'
else
    "$fish" -c 'curl -sL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source && fisher update'
fi
